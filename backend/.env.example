# ── Application ────────────────────────────────────────────────
APP_NAME="SignalStack Research API"
APP_VERSION="0.2.0"
DEBUG=true
ENVIRONMENT=development

# ── Database ───────────────────────────────────────────────────
# PostgreSQL async URL for SQLAlchemy (asyncpg driver)
# Format:
# postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/signalstack_research

# ── Clerk Authentication ───────────────────────────────────────
# Get from: https://dashboard.clerk.com/
CLERK_SECRET_KEY=sk_test_REPLACE_WITH_REAL_SECRET_KEY

# Public Clerk key used by frontend
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_REAL_PUBLISHABLE_KEY

# Clerk webhook signing secret
# Clerk Dashboard → Webhooks → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_REPLACE_WITH_REAL_WEBHOOK_SECRET

# Clerk JWKS endpoint
# Format:
# https://<your-clerk-domain>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# ── AI Providers ───────────────────────────────────────────────
# Optional — app can still run without providers using deterministic fallbacks

# Anthropic / Claude
ANTHROPIC_API_KEY=

# Gemini
GEMINI_API_KEY=

# OpenAI
OPENAI_API_KEY=

# ── External APIs ──────────────────────────────────────────────
# Optional — fallback mock/demo data used if omitted

# NewsAPI
NEWS_API_KEY=

# Alpha Vantage
ALPHA_VANTAGE_KEY=

# ── Vector Database ────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data

# ── Security / CORS ────────────────────────────────────────────
# Comma-separated origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_RESEARCH_PER_HOUR=10
RATE_LIMIT_RESEARCH_PER_DAY=100

# ── Logging ────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO